<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
    <t t-name="pos_payment_sn_base.WavePaymentDialog">
        <Dialog title="'Paiement Wave'" size="'md'" footer="false">
            <div class="text-center p-4">
                <p class="fw-bold fs-4 mb-1">
                    <t t-esc="props.amount"/> XOF
                </p>
                <p class="text-muted mb-3">Scannez avec l'application Wave</p>
                <div class="mb-3">
                    <img t-att-src="qrSrc" alt="QR Wave" style="width:280px;height:280px;"/>
                </div>
                <p class="text-muted small mb-3">Le montant est pré-rempli — confirmez avec votre code PIN.</p>
                <a t-att-href="props.waveUrl" target="_blank" class="text-muted small d-block mb-3">
                    Ou ouvrir Wave sur cet appareil
                </a>
                <div class="d-flex align-items-center justify-content-center gap-2 text-muted">
                    <span class="spinner-border spinner-border-sm" role="status"/>
                    <span>En attente de confirmation…</span>
                </div>
            </div>
        </Dialog>
    </t>
</templates>
