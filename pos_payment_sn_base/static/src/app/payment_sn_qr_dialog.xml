<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
    <t t-name="pos_payment_sn_base.WavePaymentDialog">
        <Dialog title="'Paiement Wave'" size="'md'">
            <div class="text-center p-4">
                <p class="fw-bold fs-4 mb-3">
                    <t t-esc="props.amount"/> XOF
                </p>
                <p class="mb-3">Partagez ce lien Wave avec le client :</p>
                <div class="mb-4">
                    <a t-att-href="props.waveUrl" target="_blank" class="btn btn-success btn-lg px-4">
                        Ouvrir Wave
                    </a>
                </div>
                <p class="text-muted small mb-0">En attente de confirmation du paiement…</p>
            </div>
        </Dialog>
    </t>
</templates>
