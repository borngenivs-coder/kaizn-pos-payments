<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="pos_payment_method_sn_form" model="ir.ui.view">
        <field name="name">pos.payment.method.sn.form</field>
        <field name="model">pos.payment.method</field>
        <field name="inherit_id" ref="point_of_sale.view_pos_payment_method_form"/>
        <field name="arch" type="xml">
            <field name="use_payment_terminal" position="after">
                <field name="payment_provider_id"
                       attrs="{'invisible': [('use_payment_terminal', 'not in', ['paydunya', 'wave'])],
                               'required':  [('use_payment_terminal', 'in',  ['paydunya', 'wave'])]}"
                       string="Fournisseur de paiement"/>
            </field>
        </field>
    </record>
</odoo>
