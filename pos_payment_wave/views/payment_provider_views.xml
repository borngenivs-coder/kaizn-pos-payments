<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="payment_provider_wave_form" model="ir.ui.view">
        <field name="name">payment.provider.wave.form</field>
        <field name="model">payment.provider</field>
        <field name="inherit_id" ref="payment.payment_provider_form"/>
        <field name="arch" type="xml">
            <group name="provider_config" position="after">
                <group name="wave_credentials"
                       string="Clés API Wave"
                       invisible="code != 'wave'">
                    <field name="wave_test_mode" string="Mode test"/>
                    <field name="wave_api_key"        password="True" string="Clé API"
                           invisible="wave_test_mode"/>
                    <field name="wave_webhook_secret" password="True" string="Secret Webhook (whsec_...)"
                           invisible="wave_test_mode"/>
                    <field name="wave_static_qr" widget="image" string="QR Code statique (sans API)"
                           options="{'size': [200, 200]}"
                           help="Image QR du compte Wave marchand. Utilisé en mode statique quand la Clé API n'est pas renseignée."/>
                </group>
            </group>
        </field>
    </record>
</odoo>
